# Default local development uses the Vite proxy to Tencent Cloud.
# Keep VITE_API_BASE_URL empty unless you intentionally bypass the proxy.

# Cloud API host used by the Vite dev-server proxy:
VITE_API_PROXY_TARGET=http://124.222.213.245

# Optional direct browser base URL. Do not append /api because code paths already start with /api.
# VITE_API_BASE_URL=http://124.222.213.245

# Optional local backend:
# VITE_API_PROXY_TARGET=http://localhost:5253
